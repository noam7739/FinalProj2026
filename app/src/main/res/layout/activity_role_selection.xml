<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="בחר תפקיד"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="כדי לסנכרן את המשחק, כל שחקן חייב לבחור מספר שונה"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="40dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnSelectP1"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:backgroundTint="#2E7D32"
            android:text="שחקן 1 (מארח)"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <Button
            android:id="@+id/btnSelectP2"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:backgroundTint="#1565C0"
            android:text="שחקן 2 (אורח)"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שימו לב: שחקן 1 שולט בתנועת השוער"
        android:textColor="#FFB74D"
        android:textSize="12sp"
        android:layout_marginTop="32dp"
        android:textStyle="italic"/>

</LinearLayout>